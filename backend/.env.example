# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/apt

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS — frontend origin (TanStack app)
CORS_ORIGIN=http://localhost:8080

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# Webhook URL (configure in Razorpay dashboard):
# http://localhost:3001/api/webhooks/razorpay

# Optional: public key exposed to frontend checkout
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx

# Seed admin (used by npm run seed)
SEED_ADMIN_EMAIL=admin@apexprotraders.in
SEED_ADMIN_PASSWORD=AdminPass123!

# Daily cron (6 AM IST) — protects GET/POST /api/cron/subscriptions
CRON_SECRET=change-me-to-a-long-random-cron-secret

# WhatsApp Cloud API — admin expiry digest (individual message to admin)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
ADMIN_WHATSAPP_NUMBER=919999999999

# WhatsApp group IDs per plan (Evolution API group JID, e.g. 120363xxx@g.us)
WHATSAPP_GROUP_PLAN_1=
WHATSAPP_GROUP_PLAN_2=

# Evolution API — remove expired users from groups (recommended for group admin actions)
WHATSAPP_EVOLUTION_API_URL=
WHATSAPP_EVOLUTION_INSTANCE=
WHATSAPP_EVOLUTION_API_KEY=

# Optional: custom webhook for group removal instead of Evolution API
# POST body: { "groupId": "...", "phone": "919876543210", "planKey": "plan-1" }
WHATSAPP_REMOVE_WEBHOOK_URL=

# Self-hosted cron runner (npm run cron) — set true to run once on process start
# CRON_RUN_ON_START=true
