# Frontend API (Next.js + MongoDB backend)
VITE_API_URL=http://localhost:3001

# Mock mode — set to true to run all flows without a backend (localStorage-backed mock API)
RUN_MOCK=false
# Demo logins when RUN_MOCK=true:
#   User (Plan 1 · 3 mo): user@apexprotraders.in / UserPass123!
#   Admin: admin@apexprotraders.in / AdminPass123!

# Optional analytics
# VITE_GA4_MEASUREMENT_ID=

# Legacy Supabase vars can remain until fully removed from deployment config
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
